# Base URL of the K21 Node API. All requests target ${EXPO_PUBLIC_API_URL}/api/...
#
# EXPO_PUBLIC_* vars are inlined into the client bundle (not secret).
#
# Simulator / web (same machine):  http://localhost:4000
# Physical device:  localhost will NOT resolve from the phone. Set this to your
#   development machine's LAN IP, e.g. http://192.168.1.42:4000 (find it with
#   `ipconfig` on Windows). Phone and machine must be on the same network.
EXPO_PUBLIC_API_URL=http://localhost:4000
