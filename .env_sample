# Sample environment file for K21 Calorie Tracker.
# Copy this to `.env` and fill in your real values:
#   cp .env_sample .env   (macOS/Linux)
#   copy .env_sample .env (Windows)
#
# NOTE: `.env` is gitignored and must never be committed. This sample file is
# safe to commit so others know which variables the app needs.

# ---------------------------------------------------------------------------
# AI provider for food image analysis.
# Choose ONE provider, then fill in that provider's API key + (optional) model.
# Changing these takes effect on the next scan — no server restart needed.
# ---------------------------------------------------------------------------

# Which provider to use: gemini | openai | anthropic | kimi
LLM_PROVIDER=gemini

# --- Google Gemini ---  (get a key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (GPT) ---  (get a key: https://platform.openai.com/api-keys)
# Use a vision-capable model (e.g. gpt-4o-mini, gpt-4o).
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (Claude) ---  (get a key: https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# --- Kimi / Moonshot ---  (OpenAI-compatible; get a key: https://platform.moonshot.ai/)
# Use a vision-capable model (e.g. moonshot-v1-8k-vision-preview).
KIMI_API_KEY=your-kimi-api-key-here
KIMI_MODEL=moonshot-v1-8k-vision-preview
KIMI_BASE_URL=https://api.moonshot.ai/v1

# ---------------------------------------------------------------------------
# Server (optional)
# ---------------------------------------------------------------------------
# PORT=3000
# HTTPS_PORT=3443
