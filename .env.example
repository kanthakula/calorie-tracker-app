# ===========================================================================
# K21 Calorie Tracker — environment template (monorepo root)
# ===========================================================================
# Copy to `.env` and fill in real values:   cp .env.example .env
# `.env` is gitignored and must never be committed. This template is safe to
# commit so contributors know which variables the stack needs.
#
# Each service also documents the subset it reads in its own README.
# ===========================================================================

# ---------------------------------------------------------------------------
# Database (Prisma / Postgres) — used by packages/db and api/node-api
# ---------------------------------------------------------------------------
# Matches the docker-compose.yml credentials. Change for production.
DATABASE_URL="postgresql://k21:k21_dev_password@localhost:5432/k21_calorie_tracker?schema=public"

# ---------------------------------------------------------------------------
# Node API service (api/node-api)
# ---------------------------------------------------------------------------
NODE_API_PORT=4000
# Where the Node API reaches the Python AI service for image analysis.
AI_SERVICE_URL="http://localhost:8000"
# JWT signing secret for user auth (use a long random value in production).
JWT_SECRET="change-me-to-a-long-random-string"

# Admin console (owner-only settings: branding, features, AI providers).
# BOTH must be set or the admin console is disabled. Only someone with both
# the username AND password can unlock it.
ADMIN_USERNAME="change-me-admin-username"
ADMIN_PASSWORD="change-me-to-a-strong-password"

# ---------------------------------------------------------------------------
# AI provider for food image analysis (read by the Python AI service, and by
# the Node API when it proxies/falls back). Choose ONE provider.
# Changing these takes effect on the next request — no restart needed.
# ---------------------------------------------------------------------------
# gemini | openai | anthropic | kimi
LLM_PROVIDER=gemini

# --- Google Gemini ---  (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (GPT, vision-capable) ---  (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (Claude) ---  (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# --- Kimi / Moonshot (OpenAI-compatible) ---  (https://platform.moonshot.ai/)
KIMI_API_KEY=your-kimi-api-key-here
KIMI_MODEL=moonshot-v1-8k-vision-preview
KIMI_BASE_URL=https://api.moonshot.ai/v1

# ---------------------------------------------------------------------------
# Future integrations (stubs already scaffolded in api/ai-service)
# ---------------------------------------------------------------------------
# USDA FoodData Central:  https://fdc.nal.usda.gov/api-key-signup.html
USDA_FDC_API_KEY=
# Open Food Facts needs no key. Barcode lookups use it by default.
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org

# Image storage (choose one provider for uploaded food photos).
# STORAGE_PROVIDER=s3 | gcs | azure | local
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Web app (apps/web) — only NEXT_PUBLIC_* vars reach the browser
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ---------------------------------------------------------------------------
# Mobile app (apps/mobile) — only EXPO_PUBLIC_* vars reach the device bundle
# ---------------------------------------------------------------------------
EXPO_PUBLIC_API_URL="http://localhost:4000"
